# Use Debian slim for glibc compatibility with minimal size
FROM debian:trixie-slim

ARG TARGETPLATFORM

# Install OpenSSL runtime libraries and CA certificates
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl3t64 && \
    rm -rf /var/lib/apt/lists/*

# Copy the application binary
COPY ./bin/${TARGETPLATFORM}/ptn2influx /app/ptn2influx

# Create a non-root user and group
RUN groupadd -r appgroup && useradd -r -g appgroup appuser

# Copy an entrypoint script to handle secrets
COPY ./entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Ensure the app directory is owned by the non-root user
RUN chown -R appuser:appgroup /app

# The entrypoint script will handle the secrets by copying them from /run/secrets to /app/secrets
# and then execute the main application as the non-root user
ENTRYPOINT ["/app/entrypoint.sh"]
