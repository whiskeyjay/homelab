FROM amazoncorretto:21

EXPOSE 25565/tcp
WORKDIR /minecraft

# Install udev, and wget
RUN yum install -y udev wget && yum clean all

# Download the Minecraft server jar
RUN wget -O server.jar https://piston-data.mojang.com/v1/objects/11e54c2081420a4d49db3007e66c80a22579ff2a/server.jar

# Accept the EULA
RUN echo "eula=true" > eula.txt

ENTRYPOINT cd $MC_SVR_PATH && cp /minecraft/*.* $MC_SVR_PATH && java -Xmx$MC_MEM_MAX -Xms$MC_MEM_MIN -jar ./server.jar --nogui
